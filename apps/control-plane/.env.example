ONESTEP_CP_APP_ENV=dev
ONESTEP_CP_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/onestep_control_plane
ONESTEP_CP_INGEST_TOKENS=dev-token
ONESTEP_CP_CONSOLE_AUTH_USERNAME=
ONESTEP_CP_CONSOLE_AUTH_PASSWORD=
ONESTEP_CP_CORS_ALLOW_ORIGINS=
ONESTEP_CP_INSTANCE_OFFLINE_AFTER_S=90
ONESTEP_CP_INSTANCE_HEALTH_PARTICIPATION_WINDOW_S=3600
ONESTEP_CP_TIMEZONE=Asia/Shanghai
ONESTEP_CP_API_PORT=8000
ONESTEP_CP_FRONTEND_PORT=4173
ONESTEP_CP_UI_API_BASE_URL=/

ONESTEP_CP_POSTGRES_DB=onestep_control_plane
ONESTEP_CP_POSTGRES_USER=postgres
ONESTEP_CP_POSTGRES_PASSWORD=postgres
ONESTEP_CP_POSTGRES_PORT=5432

# Used by release helper scripts when targeting an already-running stack.
ONESTEP_CP_SMOKE_READY_TIMEOUT_S=120
