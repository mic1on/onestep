# Example environment for a systemd-managed OneStep worker.
#
# For web framework projects, point APP_TARGET at the dedicated worker module,
# for example:
#   APP_TARGET=your_project.onestep_app:app

APP_CWD=/srv/onestep-app
APP_TARGET=your_package.tasks:app
ONESTEP_BIN=/srv/onestep-app/.venv/bin/onestep
